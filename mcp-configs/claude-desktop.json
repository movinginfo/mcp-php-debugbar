{
  "_comment": "For Claude Desktop — add the 'php-debugbar' block inside your existing mcpServers object in claude_desktop_config.json",
  "mcpServers": {
    "php-debugbar": {
      "command": "node",
      "args": ["e:/php/claude-project/mcp-php-debugbar/dist/index.js"],
      "env": {
        "DEBUGBAR_BASE_URL": "http://localhost:8000",
        "DEBUGBAR_TYPE": "auto",
        "CHROME_PORT": "9222"
      }
    }
  }
}
